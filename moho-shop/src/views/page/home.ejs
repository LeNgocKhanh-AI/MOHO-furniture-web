<!DOCTYPE html>
<html lang="vi">

<head>

  <meta charset="UTF-8">

  <title>MOHO</title>

  <!-- CSS -->

  <link rel="stylesheet" href="/css/client/header.css">
  <link rel="stylesheet" href="/css/client/footer.css">
  <link rel="stylesheet" href="/css/client/slide.css">
  <link rel="stylesheet" href="/css/client/trangchu.css">
  <link rel="stylesheet" href="/css/client/product.css">
  <link rel="stylesheet" href="/css/client/review.css">
  <link rel="stylesheet" href="/css/client/service-feature.css">

  <!-- FONT AWESOME -->

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

</head>

<body>

  <!-- HEADER -->

  <%- include('../partials/header') %>

    <!-- SLIDER -->

    <%- include('../partials/slide') %>

      <!-- PRODUCT SECTION -->

<!-- PRODUCT SECTION -->
      <section class="product-section">
        <div class="container-80">
<div class="section-header">
  <h2><%= titleHeading %></h2>
  <a href="#" class="view-more">Xem thêm</a>
</div>

          <div class="product-grid">
            <% products.forEach(product=> { %>
              <%- include('../partials/product', { product }) %>
            <% }) %>
          </div>

          <!-- 🔥 ĐOẠN MÃ PHÂN TRANG CHO CLIENT TRANG CHỦ 🔥 -->
          <% if (totalPages > 1) { %>
            <div class="client-pagination" style="display: flex; justify-content: center; align-items: center; gap: 10px; margin-top: 30px;">
              
              <!-- Nút lùi về trang trước -->
              <% if (currentPage > 1) { %>
                <a href="/?page=<%= currentPage - 1 %>" class="btn-page-arrow" style="padding: 8px 12px; border: 1px solid #ddd; border-radius: 4px; text-decoration: none; color: #333;"><i class="fa fa-chevron-left"></i> Trước</a>
              <% } %>

              <!-- Vòng lặp in ra danh sách các số trang -->
              <% for(let i = 1; i <= totalPages; i++) { %>
                <a
  href="/?page=<%= i %>"
  class="btn-page-number <%= currentPage === i ? 'active' : '' %>"
>
    <%= i %>
</a>
              <% } %>

              <!-- Nút tiến sang trang sau -->
              <% if (currentPage < totalPages) { %>
                <a href="/?page=<%= currentPage + 1 %>" class="btn-page-arrow" style="padding: 8px 12px; border: 1px solid #ddd; border-radius: 4px; text-decoration: none; color: #333;">Sau <i class="fa fa-chevron-right"></i></a>
              <% } %>

            </div>
          <% } %>

        </div>
      </section>
      <section class="review-section">

        <div class="container-80">

          <div class="section-header">

            <h2>Khách hàng đánh giá</h2>

          </div>

          <%- include('../partials/review', { reviews }) %>


        </div>

      </section>
      <%- include('../partials/service-feature') %>


        <!-- JS -->

        <script src="/js/slide.js"></script>
        <script src="/js/search.js"></script>
        <script src="/js/cart.js"></script>
        <script src="/js/auth.js"></script>


</body>
<%- include('../partials/footer') %>

</html>