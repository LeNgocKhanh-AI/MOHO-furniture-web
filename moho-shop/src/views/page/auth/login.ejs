<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <title>Đăng nhập</title>

    <link rel="stylesheet" href="/css/client/header.css">
    <link rel="stylesheet" href="/css/client/footer.css">
    <link rel="stylesheet" href="/css/client/service-feature.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <link rel="stylesheet" href="/css/client/login.css">
</head>

<body>

    <%- include('../../partials/header') %>

        <div class="auth-page">

            <div class="auth-card">

                <div class="auth-left">
                    <h1>Đăng nhập</h1>
                    
                    <p class="auth-desc">
                        Đăng nhập tài khoản để quản lý đơn hàng, tích lũy điểm và trải nghiệm mua sắm tốt nhất tại MOHO.
                    </p>
                    
                    <div class="auth-line-left"></div>

                    <a href="/auth/google" class="google-btn">
                        <i class="fab fa-google"></i> Đăng nhập bằng Google
                    </a>
                </div>

                <div class="auth-line"></div>

                <div class="auth-right">

                    <form id="loginForm">
                        <input name="email" type="email" placeholder="Email" required>
                        <input name="password" type="password" placeholder="Mật khẩu" required>
                        
                        <button type="submit">Đăng nhập</button>
                    </form>

                    <div class="auth-switch">
                        Chưa có tài khoản? <a href="/register">Đăng ký ngay</a>
                    </div>

                </div>

            </div>

        </div>

        <%- include('../../partials/service-feature') %>
        
        <script src="/js/search.js"></script>
        <script src="/js/cart.js"></script>
        <script src="/js/auth.js"></script>

</body>

<%- include('../../partials/footer') %>

</html>