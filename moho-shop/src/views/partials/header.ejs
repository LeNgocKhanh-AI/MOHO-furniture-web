<header class="main-header">
  <div class="container">
    <div class="logo">
      <img src="/images/banners/LogoMoho.png" alt="MOHO Logo" />
    </div>

    <div class="search-bar">

      <div class="search-box">

        <input type="text" id="searchInput" placeholder="Tìm kiếm sản phẩm..." autocomplete="off" />

        <button>
          <i class="fa fa-search"></i>
        </button>

        <!-- DROPDOWN -->
        <div id="searchDropdown" class="search-dropdown"></div>

      </div>

    </div>
    <div class="header-actions">

      <!-- ACCOUNT -->

      <div class="account">

        <i class="fa fa-user-o"></i>

        <!-- ===== LOGIN SUCCESS ===== -->

        <% if(session.customer){ %>

          <div class="account-text">

            <span>Xin chào</span>

            <div class="my-account" id="accountBox">
              <strong class="username">
                <%= session.customer.customer_firstname %>
              </strong>
              <i class="fa fa-chevron-down"></i>
            </div>

          </div>

          <!-- DROPDOWN -->
          <div class="user-dropdown" id="userDropdown">

            <a href="/account">Tài khoản của bạn</a>
            <a href="/orders">Đơn hàng của tôi</a>
            <a href="/logout">Đăng xuất</a>

          </div>

          <% } else { %>

            <!-- ===== NOT LOGIN ===== -->

            <div class="account-text">

              <span>

                Đăng nhập / Đăng ký

              </span>

              <div class="my-account">

                <strong>

                  Tài khoản của tôi

                </strong>

                <i class="fa fa-chevron-down"></i>

              </div>

            </div>

            <!-- ===== LOGIN POPUP ===== -->

            <div class="login-popup" id="loginPopup">

              <h3>

                ĐĂNG NHẬP TÀI KHOẢN

              </h3>
              <!-- LOGIN FORM -->

              <form id="loginForm">

                <!-- EMAIL -->

                <div class="floating-group">
                  <input type="email" name="email" placeholder=" " required />
                  <label>Nhập email của bạn</label>
                </div>

                <div class="floating-group">
                  <input type="password" name="password" placeholder=" " required />
                  <label>Nhập mật khẩu của bạn</label>
                </div>

                <!-- GOOGLE TEXT -->

                <div class="google-text">

                  Website được bảo vệ bởi
                  reCAPTCHA và

                  <a href="https://policies.google.com/privacy" target="_blank">

                    Chính sách bảo mật

                  </a>

                  và

                  <a href="https://policies.google.com/terms" target="_blank">

                    Điều khoản dịch vụ

                  </a>

                  của Google

                </div>

                <!-- BUTTON -->

                <button type="submit" class="login-btn">

                  ĐĂNG NHẬP

                </button>
                <a href="/auth/google" class="google-login-btn">
                  <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/google/google-original.svg" />
                  <span>Tiếp tục với Google</span>
                </a>

              </form>

              <!-- FOOTER -->

              <div class="login-bottom">

                <div class="login-row">
                  <span>Khách hàng mới?</span>

                  <a href="/register">
                    Tạo tài khoản
                  </a>
                </div>

                <div class="login-row">
                  <span>Quên mật khẩu?</span>

                  <a href="#">
                    Khôi phục mật khẩu
                  </a>
                </div>

              </div>

            </div>

            <% } %>

      </div>

      <!-- CART -->
      <div class="cart">
        <div class="cart-icon">
          <i class="fa fa-shopping-bag"></i>
          <span class="cart-count">0</span>
        </div>
        <span>Giỏ hàng</span>
      </div>
      <div class="mini-cart" id="miniCart">
        <div class="mini-cart-title">GIỎ HÀNG</div>
        <div class="mini-cart-list" id="miniCartList"></div>
        <div class="mini-cart-total" id="miniCartTotal"></div>

        <div class="mini-cart-footer">
          <a href="/cart">Xem giỏ hàng</a>
          <button>Thanh toán</button>
        </div>
      </div>
    </div>
  </div>

  <nav class="main-nav">
    <div class="main-nav-container">
      <ul>
        <li>
          <a href="/">Sản phẩm <i class="fa fa-chevron-down"></i></a>
        </li>
        <li><a href="#">Thiết kế - Thi công</a></li>
        <li>
          <a href="#">Khuyến mãi <i class="fa fa-chevron-down"></i></a>
        </li>
        <li>
          <a href="#">Tin tức <i class="fa fa-chevron-down"></i></a>
        </li>
        <li><a href="#">Về MOHO</a></li>
        <li><a href="#">Cửa hàng</a></li>
      </ul>
    </div>
  </nav>
</header>