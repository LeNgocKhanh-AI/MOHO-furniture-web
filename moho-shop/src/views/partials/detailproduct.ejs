<section class="detail-section">

    <div class="detail-container">

        <!-- LEFT -->

        <div class="detail-left">

            <!-- LEFT THUMB -->

            <div class="sub-images">

                <% images.forEach(img=>{ %>

                    <img src="<%= img.image_url %>" class="sub-img" onclick="changeImage(this)">

                    <% }) %>

            </div>

            <!-- MAIN IMAGE -->

            <div class="main-image">

                <img id="mainProductImage" src="<%= images[0].image_url %>" alt="">

            </div>

        </div>

        <!-- RIGHT -->

        <div class="detail-right">

            <h1 class="detail-name">

                <%= product.product_name %>

            </h1>

            <!-- META -->

            <div class="detail-meta">

                <div class="detail-rating">

                    <i class="fa-solid fa-star"></i>

                    <span>

                        <%= product.avg_rating %>

                    </span>

                    <span>

                        (<%= product.total_reviews %> đánh giá)

                    </span>

                </div>

                <span>|</span>

                <div>

                    Đã bán <%= product.total_sold %>

                </div>

            </div>

            <!-- SKU -->

            <div class="detail-sku">

                SKU:
                <%= product.product_sku %>

            </div>

            <div class="detail-line"></div>

            <!-- PRICE -->

            <div class="detail-price">

                <span class="sale-price" id="salePrice">

    <%= Number(product.product_sale_price).toLocaleString('vi-VN') %>đ

</span>

<span class="old-price-detail" id="oldPrice">

    <%= Number(product.product_price).toLocaleString('vi-VN') %>đ

</span>

            </div>

            <div class="detail-line"></div>
            <div class="product-size">

    <h4>Kích thước</h4>

    <div class="size-list">

        <% sizes.forEach(size=>{ %>

       <div
    class="size-item"
    data-sizeid="<%= size.size_id %>"
    data-extra="<%= size.extra_price %>"
    onclick="selectSize(this)">

    <%= size.size_name %>

</div>

        <% }) %>

    </div>

</div>

            <!-- DESC -->

            <div class="detail-desc">

                <div class="detail-desc">
    <%- product.product_description.replace(/\n/g, '<br>') %>
</div>

            </div>

            <!-- QUANTITY -->

            <div class="quantity-box">

                <button onclick="decreaseQty()">-</button>

                <input type="text" value="1" id="qtyInput" readonly>

                <button onclick="increaseQty()">+</button>

            </div>

            <!-- BUTTON -->

            <div class="detail-buttons">

                <button class="btn-cart" onclick="handleAddToCart('<%= product.product_id %>')">


                    THÊM VÀO GIỎ

                </button>

                <button class="btn-buy"
   onclick="buyNow(
'<%= product.product_id %>'
)">

                    MUA NGAY

                </button>

                <a href="https://zalo.me/0365218395" class="btn-zalo">

                    LIÊN HỆ ZALO

                </a>

            </div>

            <!-- POLICY -->

           <div class="detail-policy">
    <p>
        <i class="fa-solid fa-check" style="color: #28a745; margin-right: 5px;"></i>
        Miễn phí giao hàng & lắp đặt tại tất cả quận huyện thuộc TP.HCM, Hà Nội, Khu đô thị Ecopark, Biên Hòa và một số quận thuộc Bình Dương (*)
    </p>
    <p>
        <i class="fa-solid fa-check" style="color: #28a745; margin-right: 5px;"></i>
        Miễn phí 1 đổi 1 - Bảo hành 5 năm - Bảo trì trọn đời (**)
    </p>
    <p style=" color: #666;">
        (*) Không áp dụng cho danh mục Đồ Trang Trí và Nệm<br>
        (**) Không áp dụng cho các sản phẩm Clearance. Chỉ bảo hành 01 năm cho khung ghế, mâm và cần đối với Ghế Văn Phòng
    </p>
</div>

        </div>

    </div>

</section>

<script>

    function changeImage(el) {

        document.getElementById("mainProductImage").src = el.src;

    }

    function increaseQty() {

        const input = document.getElementById("qtyInput");

        input.value = parseInt(input.value) + 1;

    }

    function decreaseQty() {

        const input = document.getElementById("qtyInput");

        if (parseInt(input.value) > 1) {

            input.value = parseInt(input.value) - 1;

        }

    }

    const baseSale = Number("<%= product.product_sale_price %>");
const basePrice = Number("<%= product.product_price %>");

window.addEventListener("DOMContentLoaded", function () {

    const first = document.querySelector(".size-item");

    if (first) {
        first.classList.add("active");
    }

});

function selectSize(el) {

    document
        .querySelectorAll(".size-item")
        .forEach(item => item.classList.remove("active"));

    el.classList.add("active");

    const extra = Number(el.dataset.extra);

    document.getElementById("salePrice").innerText =
        (baseSale + extra).toLocaleString("vi-VN") + "đ";

    document.getElementById("oldPrice").innerText =
        (basePrice + extra).toLocaleString("vi-VN") + "đ";
}
   async function handleAddToCart(productId) {

    const activeSize =
        document.querySelector(".size-item.active");

    const sizeId =
        activeSize
            ? activeSize.dataset.sizeid
            : null;

    const img = document.querySelector(".main-image img");

    if (img && typeof flyToCart === "function") {
        flyToCart(img);
    }

    await addToCart(
        productId,
        sizeId
    );

    await loadCart();
}
    function buyNow(id){

    window.location =
    "/checkout/buy-now/" + id;
}

function buyNow(id) {
    const activeSize = document.querySelector(".size-item.active");
    const sizeId = activeSize ? activeSize.dataset.sizeid : null;
    if (!sizeId) return alert("Vui lòng chọn kích thước!");
    window.location = "/checkout/buy-now/" + id + "?sizeId=" + sizeId;
}

</script>