<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý đơn hàng</title>
  <link rel="stylesheet" href="/css/admin/admindashboard.css">
  <link rel="stylesheet" href="/css/admin/product.css">
  <link rel="stylesheet" href="/css/admin/orders.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body>

<div class="dashboard-container">
  <aside class="sidebar">
    <div class="sidebar-brand">
      <a href="/admin/dashboard"><img src="/images/banners/LogoMoho.png" alt="Moho Logo" class="sidebar-logo"></a>
    </div>

    <ul class="sidebar-menu">
      <li><a href="/admin/dashboard"><i class="fa-solid fa-chart-line"></i> Tổng quan</a></li>
      
      <li class="dropdown-product">
        <div class="dropdown-product-toggle">
          <div class="menu-left"><i class="fa-solid fa-box"></i><span>Quản lý sản phẩm</span></div>
          <i class="fa-solid fa-chevron-down arrow-product"></i>
        </div>
        <ul class="submenu-product">
          <li><a href="/admin/dashboard/product">Sản phẩm</a></li>
          <li><a href="/admin/dashboard/category">Loại sản phẩm</a></li>
          <li><a href="/admin/dashboard/product-images">Hình ảnh sản phẩm</a></li>
        </ul>
      </li>

      <li class="dropdown-orders active">
        <div class="dropdown-orders-toggle">
          <div class="menu-left"><i class="fa-solid fa-cart-shopping"></i><span>Quản lý đơn hàng</span></div>
          <i class="fa-solid fa-chevron-down arrow-orders"></i>
        </div>
<ul class="submenu-orders">
  <li>
    <a href="/admin/dashboard/orders" class="active">Đơn hàng</a>
  </li>
  <li>
    <a href="/admin/dashboard/order-details">Chi tiết đơn hàng</a>
  </li>
</ul>
      </li>

      <li class="dropdown-feedback">
        <div class="dropdown-feedback-toggle">
          <div class="menu-left"><i class="fa-solid fa-comments"></i><span>Quản lý phản hồi</span></div>
          <i class="fa-solid fa-chevron-down arrow-feedback"></i>
        </div>
        <ul class="submenu-feedback">
          <li><a href="/admin/dashboard/feedbacks">Feedback</a></li>
          <li><a href="/admin/dashboard/product-reviews">Review</a></li>
        </ul>
      </li>

      
          <li class="dropdown-product">
            <div class="dropdown-product-toggle">
              <div class="menu-left">
                <i class="fa-solid fa-newspaper"></i>
                <span>Quản lý bài viết</span>
              </div>
              <i class="fa-solid fa-chevron-down arrow-product"></i>
            </div>
            <ul class="submenu-product">
              <li>
                <a href="/admin/dashboard/posts"> Bài viết / Tin tức </a>
              </li>
            </ul>
          </li>

      <li class="dropdown-menu">
        <div class="dropdown-toggle">
          <div class="menu-left"><i class="fa-solid fa-users"></i><span>Quản lý người dùng</span></div>
          <i class="fa-solid fa-chevron-down arrow-icon"></i>
        </div>
        <ul class="submenu">
          <li><a href="/admin/dashboard/customers">Khách hàng</a></li>
          <li><a href="/admin/dashboard/admin-users">Admin</a></li>
        </ul>
      </li>
    </ul>
  </aside>

  <main class="main-content">
    <div class="dashboard-header">
      <h1>Hệ thống quản lý Đơn hàng</h1>
      <p>Danh sách các đơn đặt hàng được đồng bộ tự động theo thời gian thực từ hệ thống Client</p>
    </div>

    <div class="table-container">
      <div class="table-header">
        <h3>Lịch sử lên đơn tự động</h3>
      </div>

      <div class="table-wrapper">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Mã Đơn</th>
              <th>Khách hàng đặt</th>
              <th>Số điện thoại</th>
              <th>Thời gian tạo đơn</th>
              <th style="text-align: center;">Trạng thái đơn hàng</th>
              <th style="text-align: center;">Chi tiết</th>
            </tr>
          </thead>
          <tbody>
            <% orders.forEach(ord => { %>
            <tr>
              <td><strong>#ORD<%= ord.order_id %></strong></td>
              <td><span style="color: #2c3e50; font-weight: 500;"><%= ord.customer_name || 'Khách vãng lai' %></span></td>
              <td><%= ord.customer_phone || '---' %></td>
              <td><%= new Date(ord.order_date).toLocaleString('vi-VN', {hour12: false}) %></td>
              <td style="text-align: center;">
                <% if(ord.order_status === 'pending') { %>
                  <span class="badge-status status-pending"><i class="fa-regular fa-clock"></i> Chờ xử lý</span>
                <% } else if(ord.order_status === 'completed') { %>
                  <span class="badge-status status-completed"><i class="fa-regular fa-circle-check"></i> Hoàn thành</span>
                <% } else { %>
                  <span class="badge-status status-cancelled"><i class="fa-solid fa-ban"></i> Đã hủy bỏ</span>
                <% } %>
              </td>
              <td style="text-align: center;">
                <button type="button" class="btn-view-order btn-open-order-modal" data-id="<%= ord.order_id %>">
                  <i class="fa-solid fa-magnifying-glass"></i> Xem chi tiết các sản phẩm
                </button>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>

        <div class="pagination">
          <% if (currentPage > 1) { %><a href="/admin/dashboard/orders?page=<%= currentPage - 1 %>">← Trước</a><% } %>
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="/admin/dashboard/orders?page=<%= i %>" class="<%= i === currentPage ? 'active' : '' %>"><%= i %></a>
          <% } %>
          <% if (currentPage < totalPages) { %><a href="/admin/dashboard/orders?page=<%= currentPage + 1 %>">Sau →</a><% } %>
        </div>
      </div>
    </div>
  </main>
</div>

<div id="orderItemsModal" class="modal">
  <div class="modal-content" style="max-width: 680px; border-radius: 8px;">
    <div class="modal-header">
      <h2>Sản phẩm của đơn hàng <span id="popupOrderIdText"></span></h2>
      <span class="close-items-modal" style="cursor: pointer; font-size: 24px;">&times;</span>
    </div>
    <div class="modal-body">
      <div class="popup-order-grid" id="popupGridContainer"></div>
      <div class="modal-pagination" id="popupPaginationContainer"></div>
    </div>
  </div>
</div>

<div id="productDetailModal" class="modal" style="z-index: 1100;">
  <div class="modal-content" style="max-width: 420px; border-radius: 6px;">
    <div class="modal-header">
      <h3>Chi tiết sản phẩm</h3>
      <span class="close-detail-modal" style="cursor: pointer; font-size: 22px;">&times;</span>
    </div>
    <div class="modal-body" style="font-size: 13px; line-height: 1.6;">
      <p><strong>Tên sản phẩm:</strong> <span id="dt_name"></span></p>
      <p><strong>Mã SKU:</strong> <span id="dt_sku"></span></p>
      <div style="margin-top: 8px;">
        <strong>Mô tả:</strong>
        <div id="dt_desc" style="background:#f1f5f9; padding:8px; border-radius:4px; max-height:100px; overflow-y:auto; font-style:italic;"></div>
      </div>
    </div>
  </div>
</div>

<script src="/js/order.js"></script>
</body>
</html>