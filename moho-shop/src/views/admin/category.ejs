<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý loại sản phẩm</title>
    <link rel="stylesheet" href="/css/admin/admindashboard.css">
    <link rel="stylesheet" href="/css/admin/product.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body>

    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <a href="/admin/dashboard">
                    <img src="/images/banners/LogoMoho.png" alt="Moho Logo" class="sidebar-logo">
                </a>
            </div>

            <ul class="sidebar-menu">
                <li>
                    <a href="/admin/dashboard">
                        <i class="fa-solid fa-chart-line"></i> Tổng quan
                    </a>
                </li>

                <li class="dropdown-product active">
                    <div class="dropdown-product-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-box"></i>
                            <span>Quản lý sản phẩm</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-product"></i>
                    </div>
                    <ul class="submenu-product">
                        <li><a href="/admin/dashboard/product">Sản phẩm</a></li>
                        <li><a href="/admin/dashboard/category" class="active">Loại sản phẩm</a></li>
                        <li><a href="/admin/dashboard/product-images">Hình ảnh sản phẩm</a></li>
                    </ul>
                </li>

                <li class="dropdown-orders">
                    <div class="dropdown-orders-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-cart-shopping"></i>
                            <span>Quản lý đơn hàng</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-orders"></i>
                    </div>
                    <ul class="submenu-orders">
                        <li><a href="/admin/dashboard/orders">Đơn hàng</a></li>
                        <li><a href="/admin/dashboard/order-details">Chi tiết đơn hàng</a></li>
                    </ul>
                </li>

                <li class="dropdown-feedback">
                    <div class="dropdown-feedback-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-comments"></i>
                            <span>Quản lý phản hồi</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-feedback"></i>
                    </div>
                    <ul class="submenu-feedback">
                        <li><a href="/admin/dashboard/feedbacks">Feedback</a></li>
                        <li><a href="/admin/dashboard/product-reviews">Review</a></li>
                    </ul>
                </li>

                          <li class="dropdown-product">
            <div class="dropdown-product-toggle">
              <div class="menu-left">
                <i class="fa-solid fa-newspaper"></i>
                <span>Quản lý bài viết</span>
              </div>
              <i class="fa-solid fa-chevron-down arrow-product"></i>
            </div>
            <ul class="submenu-product">
              <li>
                <a href="/admin/dashboard/posts"> Bài viết / Tin tức </a>
              </li>
            </ul>
          </li>

                <li class="dropdown-menu">
                    <div class="dropdown-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-users"></i>
                            <span>Quản lý người dùng</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-icon"></i>
                    </div>
                    <ul class="submenu">
                        <li><a href="/admin/dashboard/customers">Khách hàng</a></li>
                        <li><a href="/admin/dashboard/admin-users">Admin</a></li>
                    </ul>
                </li>
            </ul>
        </aside>

        <main class="main-content">
            <div class="dashboard-header">
                <h1>Quản lý loại sản phẩm</h1>
                <p>Danh sách danh mục sản phẩm trong hệ thống</p>
            </div>

            <div class="table-container">
                <div class="table-header">
                    <h3>Danh sách danh mục</h3>
                    <button id="openCategoryModal" class="btn-add">+ Thêm danh mục</button>
                </div>

                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Mã loại sản phẩm</th>
                                <th>Tên loại sản phẩm</th>
                                <th>Mô tả về loại sản phẩm</th>
                                <th style="text-align: center;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% categories.forEach(category=> { %>
                                <tr>
                                    <td>
                                        <%= category.cat_id %>
                                    </td>
                                    <td><strong>
                                            <%= category.cat_name %>
                                        </strong></td>
                                    <td>
                                        <%= category.cat_desc || 'Chưa có mô tả' %>
                                    </td>
                                    <td class="actions-cell">
                                        <a href="#" class="btn-edit edit-cat-btn" data-id="<%= category.cat_id %>"
                                            data-name="<%= category.cat_name %>" data-desc="<%= category.cat_desc %>">
                                            Sửa
                                        </a>
                                        <a href="/admin/dashboard/category/delete/<%= category.cat_id %>"
                                            class="btn-delete"
                                            onclick="return confirm('Bạn có chắc muốn xoá danh mục này?')">
                                            Xoá
                                        </a>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>

                    <div class="pagination">
                        <% if (currentPage> 1) { %>
                            <a href="/admin/dashboard/category?page=<%= currentPage - 1 %>">
                                ← Trước
                            </a>
                            <% } %>

                                <% for (let i=1; i <=totalPages; i++) { %>
                                    <a href="/admin/dashboard/category?page=<%= i %>"
                                        class="<%= i === currentPage ? 'active' : '' %>">
                                        <%= i %>
                                    </a>
                                    <% } %>

                                        <% if (currentPage < totalPages) { %>
                                            <a href="/admin/dashboard/category?page=<%= currentPage + 1 %>">
                                                Sau →
                                            </a>
                                            <% } %>
                    </div>

                </div>
            </div>
        </main>
    </div>

    <div id="categoryModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Thêm danh mục</h2>
                <span class="close-cat-modal">&times;</span>
            </div>
            <form action="/admin/dashboard/category/create" method="POST">
                <div class="form-group">
                    <label>Tên danh mục</label>
                    <input type="text" name="cat_name" required>
                </div>
                <div class="form-group">
                    <label>Mô tả danh mục</label>
                    <textarea name="cat_desc" rows="4"></textarea>
                </div>
                <button type="submit" class="btn-save">Lưu danh mục</button>
            </form>
        </div>
    </div>

    <div id="editCategoryModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Sửa danh mục</h2>
                <span class="close-edit-cat">&times;</span>
            </div>
            <form id="editCategoryForm" method="POST">
                <input type="hidden" name="cat_id" id="edit_cat_id">
                <div class="form-group">
                    <label>Tên danh mục</label>
                    <input type="text" name="cat_name" id="edit_cat_name" required>
                </div>
                <div class="form-group">
                    <label>Mô tả danh mục</label>
                    <textarea name="cat_desc" id="edit_cat_desc" rows="4"></textarea>
                </div>
                <button type="submit" class="btn-save">Cập nhật</button>
            </form>
        </div>
    </div>

    <script src="/js/category.js"></script>
</body>

</html>