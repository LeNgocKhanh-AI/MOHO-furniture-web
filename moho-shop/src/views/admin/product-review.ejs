<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý đánh giá sản phẩm</title>
    <link rel="stylesheet" href="/css/admin/admindashboard.css">
    <link rel="stylesheet" href="/css/admin/product.css">
    <link rel="stylesheet" href="/css/admin/product-review.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        .star-rating {
            color: #f39c12;
        }

        .review-img {
            width: 50px;
            height: 50px;
            object-fit: cover;
            border-radius: 4px;
            border: 1px solid #ddd;
        }
    </style>
</head>

<body>

    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <a href="/admin/dashboard">
                    <img src="/images/banners/LogoMoho.png" alt="Moho Logo" class="sidebar-logo">
                </a>
            </div>

            <ul class="sidebar-menu">
                <li>
                    <a href="/admin/dashboard">
                        <i class="fa-solid fa-chart-line"></i> Tổng quan
                    </a>
                </li>

                <li class="dropdown-product">
                    <div class="dropdown-product-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-box"></i>
                            <span>Quản lý sản phẩm</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-product"></i>
                    </div>
                    <ul class="submenu-product">
                        <li><a href="/admin/dashboard/product">Sản phẩm</a></li>
                        <li><a href="/admin/dashboard/category">Loại sản phẩm</a></li>
                        <li><a href="/admin/dashboard/product-images">Hình ảnh sản phẩm</a></li>
                    </ul>
                </li>

                <li class="dropdown-orders">
                    <div class="dropdown-orders-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-cart-shopping"></i>
                            <span>Quản lý đơn hàng</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-orders"></i>
                    </div>
                    <ul class="submenu-orders">
                        <li><a href="/admin/orders">Đơn hàng</a></li>
                        <li><a href="/admin/order-details">Chi tiết đơn hàng</a></li>
                    </ul>
                </li>

                <li class="dropdown-feedback active">
                    <div class="dropdown-feedback-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-comments"></i>
                            <span>Quản lý phản hồi</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-feedback"></i>
                    </div>
                    <ul class="submenu-feedback">
                        <li><a href="/admin/dashboard/feedbacks">Feedback</a></li>
                        <li><a href="/admin/dashboard/product-reviews" class="active">Review</a></li>
                    </ul>
                </li>

                <li class="dropdown-menu">
                    <div class="dropdown-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-users"></i>
                            <span>Quản lý người dùng</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-icon"></i>
                    </div>
                    <ul class="submenu">
                        <li><a href="/admin/dashboard/customers">Khách hàng</a></li>
                        <li><a href="/admin/admin-users">Admin</a></li>
                    </ul>
                </li>
            </ul>
        </aside>

        <main class="main-content">
            <div class="dashboard-header">
                <h1>Quản lý đánh giá sản phẩm</h1>
                <p>Xem ý kiến phản hồi và quản lý các đánh giá từ người tiêu dùng</p>
            </div>

            <div class="table-container">
                <div class="table-header">
                    <h3>Danh sách ý kiến từ khách hàng</h3>
                </div>

                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Mã đánh giá</th>
                                <th>Mã khách hàng</th>
                                <th>Mã sản phẩm</th>
                                <th>Đánh giá</th>
                                <th>Nội dung review</th>
                                <th>Ảnh Review</th>
                                <th>Anonymous</th>
                                <th>Ngày đánh giá</th>
                                <th style="text-align: center;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% reviews.forEach(review=> { %>
                                <tr>
                                    <td>
                                        <%= review.review_id %>
                                    </td>
                                    <td><strong>
                                            <%= review.anonymous ? 'Người dùng ẩn danh ' : ('Mã KH: ' + review.customer_id) %></strong></td>
              <td><small><%= review.product_name %></small></td>
              <td>
                <div class="star-rating">
                  <% for(let i=1; i<=5; i++) { %>
                    <i class="<%= i <= review.rating ? ' fa-solid' : 'fa-regular' %> fa-star"></i>
                                                <% } %>
                </div>
                </td>
                <td>
                    <%= review.review_comment || '--- Không có nội dung bình luận ---' %>
                </td>
                <td>
                    <% if(review.review_image) { %>
                        <a href="<%= review.review_image %>" target="_blank">
                            <img src="<%= review.review_image %>" class="review-img" alt="Review Evidence">
                        </a>
                        <% } else { %>
                            <span style="color:#aaa;"><small>Không có ảnh</small></span>
                            <% } %>
                </td>
                <td>
                    <span class="review-status <%= review.anonymous ? 'anonymous' : 'public' %>">
                        <i class="fa-solid <%= review.anonymous ? 'fa-user-secret' : 'fa-earth-asia' %>"></i>
                        <%= review.anonymous ? 'Ẩn danh' : 'Công khai' %>
                    </span>
                </td>
                <td><small>
                        <%= new Date(review.created_at).toLocaleDateString("vi-VN") %>
                    </small></td>
                <td style="text-align: center;">
                    <a href="/admin/dashboard/product-reviews/delete/<%= review.review_id %>" class="btn-delete"
                        onclick="return confirm('Bạn có chắc chắn muốn xoá vĩnh viễn đánh giá này? Việc này không thể hoàn tác!')">
                        Xoá đánh giá
                    </a>
                </td>
                </tr>
                <% }) %>
                    </tbody>
                    </table>

                    <div class="pagination">
                        <% if (currentPage> 1) { %>
                            <a href="/admin/dashboard/product-reviews?page=<%= currentPage - 1 %>">← Trước</a>
                            <% } %>
                                <% for (let i=1; i <=totalPages; i++) { %>
                                    <a href="/admin/dashboard/product-reviews?page=<%= i %>"
                                        class="<%= i === currentPage ? 'active' : '' %>">
                                        <%= i %>
                                    </a>
                                    <% } %>
                                        <% if (currentPage < totalPages) { %>
                                            <a href="/admin/dashboard/product-reviews?page=<%= currentPage + 1 %>">Sau
                                                →</a>
                                            <% } %>
                    </div>
            </div>
    </div>
    </main>
    </div>

    <script src="/js/product-review.js"></script>
</body>

</html>