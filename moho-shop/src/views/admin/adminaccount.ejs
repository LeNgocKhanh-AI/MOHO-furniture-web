<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Danh sách Quản trị viên</title>
  <link rel="stylesheet" href="/css/admin/admindashboard.css">
  <link rel="stylesheet" href="/css/admin/product.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    .read-only-table th { background-color: #2c3e50 !important; color: white; }
    .read-only-table tbody tr:hover { background-color: #f8fafc; }
    .text-mono { font-family: monospace; font-weight: bold; color: #475569; }
    .badge-admin { padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: bold; background-color: #34495e; color: #fff; }
  </style>
</head>

<body>

<div class="dashboard-container">
  <aside class="sidebar">
    <div class="sidebar-brand">
      <a href="/admin/dashboard"><img src="/images/banners/LogoMoho.png" alt="Moho Logo" class="sidebar-logo"></a>
    </div>

    <ul class="sidebar-menu">
      <li><a href="/admin/dashboard"><i class="fa-solid fa-chart-line"></i> Tổng quan</a></li>

      <li class="dropdown-product">
        <div class="dropdown-product-toggle">
          <div class="menu-left"><i class="fa-solid fa-box"></i><span>Quản lý sản phẩm</span></div>
          <i class="fa-solid fa-chevron-down arrow-product"></i>
        </div>
        <ul class="submenu-product">
          <li><a href="/admin/dashboard/product">Sản phẩm</a></li>
          <li><a href="/admin/dashboard/category">Loại sản phẩm</a></li>
          <li><a href="/admin/dashboard/product-images">Hình ảnh sản phẩm</a></li>
              <li><a href="/admin/dashboard/product-sizes">Kích thước sản phẩm</a></li>
        </ul>
      </li>

      <li class="dropdown-orders">
        <div class="dropdown-orders-toggle">
          <div class="menu-left"><i class="fa-solid fa-cart-shopping"></i><span>Quản lý đơn hàng</span></div>
          <i class="fa-solid fa-chevron-down arrow-orders"></i>
        </div>
        <ul class="submenu-orders">
          <li><a href="/admin/dashboard/orders">Đơn hàng</a></li>
          <li><a href="/admin/dashboard/order-details">Chi tiết đơn hàng</a></li>
        </ul>
      </li>

      <li class="dropdown-feedback">
        <div class="dropdown-feedback-toggle">
          <div class="menu-left"><i class="fa-solid fa-comments"></i><span>Quản lý phản hồi</span></div>
          <i class="fa-solid fa-chevron-down arrow-feedback"></i>
        </div>
        <ul class="submenu-feedback">
          <li><a href="/admin/dashboard/feedbacks">Feedback</a></li>
          <li><a href="/admin/dashboard/product-reviews">Review</a></li>
        </ul>
      </li>

      <li class="dropdown-menu active">
        <div class="dropdown-toggle">
          <div class="menu-left"><i class="fa-solid fa-users"></i><span>Quản lý người dùng</span></div>
          <i class="fa-solid fa-chevron-down arrow-icon"></i>
        </div>
        <ul class="submenu">
          <li><a href="/admin/dashboard/customers">Khách hàng</a></li>
          <li><a href="/admin/dashboard/admin-users" class="active">Admin</a></li>
        </ul>
      </li>
    </ul>
  </aside>

  <main class="main-content">
    <div class="dashboard-header">
      <h1>Thông tin về các quản trị viên</h1>
      <p>Danh sách các tài khoản nội bộ có quyền truy cập vào hệ thống Admin Dashboard</p>
    </div>

    <div class="table-container">
      <div class="table-header">
        <h3>Danh sách thành viên quản trị viên</h3>
      </div>

      <div class="table-wrapper">
        <table class="admin-table read-only-table">
          <thead>
            <tr>
              <th>ID Admin</th>
              <th>Tên tài khoản</th>
              <th>Họ và tên</th>
              <th>Email liên hệ</th>
              <th>Số điện thoại</th>
              <th>Địa chỉ cư trú</th>
              <th style="text-align: center;">Phân quyền</th>
            </tr>
          </thead>
          <tbody>
            <% if (admins.length === 0) { %>
              <tr>
                <td colspan="7" style="text-align: center; color: #94a3b8; padding: 20px;">Không có dữ liệu admin nào.</td>
              </tr>
            <% } %>
            
            <% admins.forEach(admin => { %>
            <tr>
              <td class="text-mono">#ADM<%= admin.admin_id %></td>
              <td><strong style="color: #2c3e50;"><%= admin.admin_username %></strong></td>
              <td><%= (admin.admin_lastname || '') + ' ' + (admin.admin_firstname || '') || 'Chưa cập nhật' %></td>
              <td><small><%= admin.admin_email || 'Chưa cung cấp' %></small></td>
              <td><%= admin.admin_phone || '---' %></td>
              <td><small><%= admin.admin_address || '---' %></small></td>
              <td style="text-align: center;"><span class="badge-admin">Administrator</span></td>
            </tr>
            <% }) %>
          </tbody>
        </table>

        <div class="pagination">
          <% if (currentPage > 1) { %>
            <a href="/admin/dashboard/admin-users?page=<%= currentPage - 1 %>">← Trước</a>
          <% } %>
          
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="/admin/dashboard/admin-users?page=<%= i %>" class="<%= i === currentPage ? 'active' : '' %>"><%= i %></a>
          <% } %>
          
          <% if (currentPage < totalPages) { %>
            <a href="/admin/dashboard/admin-users?page=<%= currentPage + 1 %>">Sau →</a>
          <% } %>
        </div>
      </div>
    </div>
  </main>
</div>
<script src="/js/adminaccount.js"></script>
</body>
</html>