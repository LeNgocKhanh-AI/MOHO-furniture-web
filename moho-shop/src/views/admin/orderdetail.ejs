<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Báo cáo Chi tiết đơn hàng</title>
  <link rel="stylesheet" href="/css/admin/admindashboard.css">
  <link rel="stylesheet" href="/css/admin/product.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    /* CSS bổ sung để tối ưu hóa trải nghiệm "Chỉ xem" */
    .read-only-table th { background-color: #2c3e50 !important; color: white; }
    .read-only-table tbody tr:hover { background-color: #f8fafc; }
    .text-mono { font-family: monospace; font-weight: bold; color: #334155; }
    .text-price { color: #e11d48; font-weight: bold; }
    .badge-order { padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: bold; background-color: #e2e8f0; color: #475569; display: inline-block; }
  </style>
</head>

<body>

<div class="dashboard-container">
  <aside class="sidebar">
    <div class="sidebar-brand">
      <a href="/admin/dashboard"><img src="/images/banners/LogoMoho.png" alt="Moho Logo" class="sidebar-logo"></a>
    </div>

    <ul class="sidebar-menu">
      <li><a href="/admin/dashboard"><i class="fa-solid fa-chart-line"></i> Tổng quan</a></li>

      <li class="dropdown-product">
        <div class="dropdown-product-toggle">
          <div class="menu-left"><i class="fa-solid fa-box"></i><span>Quản lý sản phẩm</span></div>
          <i class="fa-solid fa-chevron-down arrow-product"></i>
        </div>
        <ul class="submenu-product">
          <li><a href="/admin/dashboard/product">Sản phẩm</a></li>
          <li><a href="/admin/dashboard/category">Loại sản phẩm</a></li>
          <li><a href="/admin/dashboard/product-images">Hình ảnh sản phẩm</a></li>
        </ul>
      </li>

      <li class="dropdown-orders active">
        <div class="dropdown-orders-toggle">
          <div class="menu-left"><i class="fa-solid fa-cart-shopping"></i><span>Quản lý đơn hàng</span></div>
          <i class="fa-solid fa-chevron-down arrow-orders"></i>
        </div>
        <ul class="submenu-orders">
          <li><a href="/admin/dashboard/orders">Đơn hàng</a></li>
          <li><a href="/admin/dashboard/order-details" class="active">Chi tiết đơn hàng</a></li>
        </ul>
      </li>

      <li class="dropdown-feedback">
        <div class="dropdown-feedback-toggle">
          <div class="menu-left"><i class="fa-solid fa-comments"></i><span>Quản lý phản hồi</span></div>
          <i class="fa-solid fa-chevron-down arrow-feedback"></i>
        </div>
        <ul class="submenu-feedback">
          <li><a href="/admin/dashboard/feedbacks">Feedback</a></li>
          <li><a href="/admin/dashboard/product-reviews">Review</a></li>
        </ul>
      </li>

      
          <li class="dropdown-product">
            <div class="dropdown-product-toggle">
              <div class="menu-left">
                <i class="fa-solid fa-newspaper"></i>
                <span>Quản lý bài viết</span>
              </div>
              <i class="fa-solid fa-chevron-down arrow-product"></i>
            </div>
            <ul class="submenu-product">
              <li>
                <a href="/admin/dashboard/posts"> Bài viết / Tin tức </a>
              </li>
            </ul>
          </li>

      <li class="dropdown-menu">
        <div class="dropdown-toggle">
          <div class="menu-left"><i class="fa-solid fa-users"></i><span>Quản lý người dùng</span></div>
          <i class="fa-solid fa-chevron-down arrow-icon"></i>
        </div>
        <ul class="submenu">
          <li><a href="/admin/dashboard/customers">Khách hàng</a></li>
          <li><a href="/admin/dashboard/admin-users">Admin</a></li>
        </ul>
      </li>
    </ul>
  </aside>

  <main class="main-content">
    <div class="dashboard-header">
      <h1>Dữ liệu Chi tiết Đơn hàng</h1>
      <p>Danh sách các mặt hàng nằm trong hóa đơn hệ thống Client</p>
    </div>

    <div class="table-container">
      <div class="table-header">
        <h3>Chi tiết đơn hàng</h3>
      </div>

      <div class="table-wrapper">
        <table class="admin-table read-only-table">
          <thead>
            <tr>
              <th>ID Bản ghi</th>
              <th>Mã Đơn hàng</th>
              <th>Mã SKU</th>
              <th>Tên sản phẩm</th>
              <th style="text-align: center;">Số lượng mua</th>
              <th style="text-align: right;">Đơn giá</th>
              <th style="text-align: right;">Thành tiền</th>
            </tr>
          </thead>
          <tbody>
            <% if (orderDetails.length === 0) { %>
              <tr>
                <td colspan="7" style="text-align: center; color: #94a3b8; padding: 20px;">Không có dữ liệu chi tiết đơn hàng nào.</td>
              </tr>
            <% } %>
            
            <% orderDetails.forEach(item => { %>
            <tr>
              <td class="text-mono">#REC<%= item.id %></td>
              <td><span class="badge-order">#ORD<%= item.order_id %></span></td>
              <td class="text-mono"><%= item.product_sku || '---' %></td>
              <td><strong style="color: #1e293b;"><%= item.product_name || 'Sản phẩm đã bị xóa khỏi hệ thống' %></strong></td>
              <td style="text-align: center; font-weight: 600;">x<%= item.quantity %></td>
              <td style="text-align: right;"><%= Number(item.unit_price).toLocaleString('vi-VN') %> đ</td>
              <td style="text-align: right;" class="text-price"><%= Number(item.total_price).toLocaleString('vi-VN') %> đ</td>
            </tr>
            <% }) %>
          </tbody>
        </table>

        <div class="pagination">
          <% if (currentPage > 1) { %>
            <a href="/admin/dashboard/order-details?page=<%= currentPage - 1 %>">← Trước</a>
          <% } %>
          
          <% for (let i = 1; i <= totalPages; i++) { %>
            <a href="/admin/dashboard/order-details?page=<%= i %>" class="<%= i === currentPage ? 'active' : '' %>"><%= i %></a>
          <% } %>
          
          <% if (currentPage < totalPages) { %>
            <a href="/admin/dashboard/order-details?page=<%= currentPage + 1 %>">Sau →</a>
          <% } %>
        </div>
      </div>
    </div>
  </main>
</div>

<script src="/js/orderdetails.js"></script>
</body>
</html>