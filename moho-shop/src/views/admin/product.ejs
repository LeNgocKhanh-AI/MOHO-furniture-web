<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý sản phẩm</title>
    <link rel="stylesheet" href="/css/admin/admindashboard.css">
    <link rel="stylesheet" href="/css/admin/product.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script src="https://cdn.ckeditor.com/ckeditor5/41.1.0/classic/ckeditor.js"></script>
</head>

<body>

    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <a href="/admin/dashboard">
                    <img src="/images/banners/LogoMoho.png" alt="Moho Logo" class="sidebar-logo">
                </a>
            </div>

            <ul class="sidebar-menu">
                <li>
                    <a href="/admin/dashboard">
                        <i class="fa-solid fa-chart-line"></i> Tổng quan
                    </a>
                </li>

                <li class="dropdown-product active">
                    <div class="dropdown-product-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-box"></i>
                            <span>Quản lý sản phẩm</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-product"></i>
                    </div>
                    <ul class="submenu-product">
                        <li><a href="/admin/dashboard/product" class="active">Sản phẩm</a></li>
                        <li><a href="/admin/dashboard/category">Loại sản phẩm</a></li>
                        <li><a href="/admin/dashboard/product-images">Hình ảnh sản phẩm</a></li>
                        <li><a href="/admin/dashboard/product-sizes">Kích thước sản phẩm</a></li>
                    </ul>
                </li>

                <li class="dropdown-orders">
                    <div class="dropdown-orders-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-cart-shopping"></i>
                            <span>Quản lý đơn hàng</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-orders"></i>
                    </div>
                    <ul class="submenu-orders">
                        <li><a href="/admin/dashboard/orders">Đơn hàng</a></li>
                        <li><a href="/admin/dashboard/order-details">Chi tiết đơn hàng</a></li>
                    </ul>
                </li>

                <li class="dropdown-feedback">
                    <div class="dropdown-feedback-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-comments"></i>
                            <span>Quản lý phản hồi</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-feedback"></i>
                    </div>
                    <ul class="submenu-feedback">
                        <li><a href="/admin/dashboard/feedbacks">Feedback</a></li>
                        <li><a href="/admin/dashboard/product-reviews">Review</a></li>
                    </ul>
                </li>

                <li class="dropdown-product">
                    <div class="dropdown-product-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-newspaper"></i>
                            <span>Quản lý bài viết</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-product"></i>
                    </div>
                    <ul class="submenu-product">
                        <li>
                            <a href="/admin/dashboard/posts"> Bài viết / Tin tức </a>
                        </li>
                    </ul>
                </li>

                <li class="dropdown-menu">
                    <div class="dropdown-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-users"></i>
                            <span>Quản lý người dùng</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-icon"></i>
                    </div>
                    <ul class="submenu">
                        <li><a href="/admin/dashboard/customers">Khách hàng</a></li>
                        <li><a href="/admin/dashboard/admin-users">Admin</a></li>
                    </ul>
                </li>
            </ul>
        </aside>

        <main class="main-content">
            <div class="dashboard-header">
                <h1>Quản lý sản phẩm</h1>
                <p>Danh sách sản phẩm trong hệ thống</p>
            </div>

            <div class="table-container">
                <div class="table-header">
                    <h3>Danh sách sản phẩm</h3>
                    <button id="openProductModal" class="btn-add">+ Thêm sản phẩm</button>
                </div>

                <div class="table-wrapper">
<div class="search-box" style="margin-bottom:20px;">
    <input
        type="text"
        id="searchProduct"
        placeholder="Tìm theo ID, tên hoặc SKU..."
        style="width:300px;padding:10px;border:1px solid #ccc;border-radius:6px;"
    >
</div>

<p id="notFound"
   style="display:none;text-align:center;color:red;font-weight:bold;">
    Không tìm thấy sản phẩm!
</p>
                    <div class="product-grid">
                        <% products.forEach(product=> { %>
                            <div class="product-card"
     data-id="<%= product.product_id %>"
     data-name="<%= product.product_name.toLowerCase() %>"
     data-sku="<%= (product.product_sku || '').toLowerCase() %>">
                                <div class="product-card-img">
                                    <% if (product.product_image) { %>
                                        <img src="<%= product.product_image %>" alt="<%= product.product_name %>"
                                            onerror="this.src='https://placehold.co/300x200?text=Moho+Shop'">
                                        <% } else { %>
                                            <img src="https://placehold.co/300x200?text=Chưa+có+ảnh" alt="No image">
                                            <% } %>
                                                <span class="stock-badge">Tồn kho: <%= product.product_stock_quantity %></span>
                                </div>

                                <div class="product-card-info">
                                    <span class="product-sku">Mã hàng: <%= product.product_sku || ('SP' + product.product_id) %></span>
                                    <h4 class="product-title" title="<%= product.product_name %>">
                                        <%= product.product_name %>
                                    </h4>
                                    <div class="product-price-box">
                                        <span class="price-sale">
                                            <%= Number(product.product_sale_price || 0).toLocaleString("vi-VN") %> đ
                                        </span>
                                        <% if (product.product_price> product.product_sale_price) { %>
                                            <span class="price-origin">
                                                <%= Number(product.product_price).toLocaleString("vi-VN") %> đ
                                            </span>
                                            <% } %>
                                    </div>
                                </div>

                                <div class="product-card-actions">
                                    <button type="button" class="btn-card-action btn-view-detail"
                                        data-id="<%= product.product_id %>" data-name="<%= product.product_name %>"
                                        data-category="<%= product.category_id %>"
                                        data-price="<%= product.product_price %>"
                                        data-sale="<%= product.product_sale_price %>"
                                        data-sku="<%= product.product_sku %>"
                                        data-stock="<%= product.product_stock_quantity %>"
                                        data-desc="<%= product.product_description %>">
                                        <i class="fa-regular fa-eye"></i> Xem
                                    </button>

                                    <button type="button" class="btn-card-action btn-edit-trigger edit-btn"
                                        data-id="<%= product.product_id %>" data-name="<%= product.product_name %>"
                                        data-category="<%= product.category_id %>"
                                        data-price="<%= product.product_price %>"
                                        data-sale="<%= product.product_sale_price %>"
                                        data-sku="<%= product.product_sku %>"
                                        data-stock="<%= product.product_stock_quantity %>"
                                        data-desc="<%= product.product_description %>"
                                        data-featured="<%= product.is_featured %>">
                                        <i class="fa-regular fa-pen-to-square"></i> Sửa
                                    </button>

                                    <a href="/admin/dashboard/product/delete/<%= product.product_id %>"
                                        class="btn-card-action btn-delete-trigger"
                                        onclick="return confirm('Bạn có chắc muốn xoá sản phẩm này?')">
                                        <i class="fa-regular fa-trash-can"></i> Xóa
                                    </a>
                                </div>

                            </div>
                            <% }) %>
                    </div>

                    <div class="pagination">
                        <% if (currentPage> 1) { %>
                            <a href="/admin/dashboard/product?page=<%= currentPage - 1 %>">← Trước</a>
                            <% } %>
                                <% for (let i=1; i <=totalPages; i++) { %>
                                    <a href="/admin/dashboard/product?page=<%= i %>"
                                        class="<%= i === currentPage ? 'active' : '' %>">
                                        <%= i %>
                                    </a>
                                    <% } %>
                                        <% if (currentPage < totalPages) { %>
                                            <a href="/admin/dashboard/product?page=<%= currentPage + 1 %>">Sau →</a>
                                            <% } %>
                    </div>

                </div>
            </div>
        </main>
    </div>

    <div id="productModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Thêm sản phẩm</h2>
                <span class="close-modal">&times;</span>
            </div>
            <form action="/admin/dashboard/product/create" method="POST">
                <div class="form-group">
                    <label>Tên sản phẩm</label>
                    <input type="text" name="product_name" required>
                </div>
                <div class="form-group">
                    <label>Danh mục</label>
                    <select name="category_id">
                        <% categories.forEach(category=> { %>
                            <option value="<%= category.cat_id %>">
                                <%= category.cat_name %>
                            </option>
                            <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label>Giá</label>
                    <input type="number" name="product_price" required>
                </div>
                <div class="form-group">
                    <label>Giá khuyến mãi</label>
                    <input type="number" name="product_sale_price">
                </div>
                <div class="form-group">
                    <label>SKU</label>
                    <input type="text" name="product_sku">
                </div>
                <div class="form-group">
                    <label>Số lượng tồn</label>
                    <input type="number" name="product_stock_quantity" value="0" readonly>
                </div>
                <div class="form-group">
                    <label>Mô tả</label>
                    <textarea id="create_description" name="product_description"></textarea>
                </div>
                <div class="checkbox-inline">
                    <input type="checkbox" name="is_featured" id="is_featured" value="1">
                    <label for="is_featured">Không hiển thị lên trang chủ</label>
                </div>
                <button type="submit" class="btn-save">Lưu sản phẩm</button>
            </form>
        </div>
    </div>

    <div id="editModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Sửa sản phẩm</h2>
                <span class="close-edit">&times;</span>
            </div>
            <form id="editForm" method="POST">
                <input type="hidden" name="product_id" id="edit_id">
                <div class="form-group">
                    <label>Tên sản phẩm</label>
                    <input type="text" name="product_name" id="edit_name">
                </div>
                <div class="form-group">
                    <label>Danh mục</label>
                    <select name="category_id" id="edit_category">
                        <% categories.forEach(category=> { %>
                            <option value="<%= category.cat_id %>">
                                <%= category.cat_name %>
                            </option>
                            <% }) %>
                    </select>
                </div>
                <div class="form-group">
                    <label>Giá</label>
                    <input type="number" name="product_price" id="edit_price">
                </div>
                <div class="form-group">
                    <label>Giá khuyến mãi</label>
                    <input type="number" name="product_sale_price" id="edit_sale">
                </div>
                <div class="form-group">
                    <label>SKU</label>
                    <input type="text" name="product_sku" id="edit_sku">
                </div>
                <div class="form-group">
                    <label>Số lượng tồn</label>
                    <input type="number" name="product_stock_quantity" id="edit_stock" readonly>
                </div>
                <div class="form-group">
                    <label>Mô tả</label>
                    <textarea id="edit_description" name="product_description"></textarea>
                </div>
                <div class="checkbox-inline">
                    <input type="checkbox" name="is_featured" id="edit_featured" value="1">
                    <label for="is_featured">Không hiển thị lên trang chủ</label>
                </div>
                <button type="submit" class="btn-save">Cập nhật</button>
            </form>
        </div>
    </div>

    <div id="viewDetailModal" class="modal">
        <div class="modal-content" style="max-width: 480px;">
            <div class="modal-header">
                <h2>Chi tiết sản phẩm</h2>
                <span class="close-view-detail">&times;</span>
            </div>
            <div class="modal-body" style="padding: 15px 0; font-size: 14px; line-height: 1.8;">
                <p><strong>Tên sản phẩm:</strong> <span id="v_name"></span></p>
                <p><strong>Mã SKU:</strong> <span id="v_sku"></span></p>
                <p><strong>Mã danh mục:</strong> <span id="v_category"></span></p>
                <p><strong>Giá niêm yết:</strong> <span id="v_price" style="text-decoration: line-through; color: #888;"></span></p>
                <p><strong>Giá bán hiện tại:</strong> <span id="v_sale" style="color: #e74c3c; font-weight: bold;"></span></p>
                <p><strong>Tồn kho hệ thống:</strong> <span id="v_stock" style="font-weight: bold;"></span></p>
                <div style="margin-top: 10px;">
                    <strong>Mô tả chi tiết:</strong>
                    <div id="v_desc" style="background: #f8f9fa; padding: 10px; border-radius: 4px; margin-top: 5px; font-style: italic; white-space: pre-line; max-height: 150px; overflow-y: auto;"></div>
                </div>
            </div>
            <div class="modal-footer" style="text-align: right; margin-top: 10px;">
                <button type="button" class="btn-save close-view-detail"
                    style="background-color: #95a5a6; border: none; padding: 8px 16px;">Đóng</button>
            </div>
        </div>
    </div>

    <script>
        let createEditor;
        let editEditor;

        ClassicEditor
            .create(document.querySelector('#create_description'))
            .then(editor => { createEditor = editor; })
            .catch(error => { console.error(error); });

        ClassicEditor
            .create(document.querySelector('#edit_description'))
            .then(editor => { editEditor = editor; })
            .catch(error => { console.error(error); });
    </script>
<script>
    document.getElementById('editForm').addEventListener('submit', function() {
        if (typeof editEditor !== 'undefined' && editEditor) {
            document.getElementById('edit_description').value = editEditor.getData();
        }
    });
</script>
    <script src="/js/product.js"></script>
</body>

</html>