<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý tin tức / bài viết</title>
    <link rel="stylesheet" href="/css/admin/admindashboard.css">
    <link rel="stylesheet" href="/css/admin/product.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        .post-thumbnail-img { width: 80px; height: 50px; object-fit: cover; border-radius: 4px; }
        .text-truncate { max-width: 200px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    </style>
</head>

<body>
    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <a href="/admin/dashboard">
                    <img src="/images/banners/LogoMoho.png" alt="Moho Logo" class="sidebar-logo">
                </a>
            </div>

            <ul class="sidebar-menu">
                <li>
                    <a href="/admin/dashboard">
                        <i class="fa-solid fa-chart-line"></i> Tổng quan
                    </a>
                </li>

                <li class="dropdown-product">
                    <div class="dropdown-product-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-box"></i> <span>Quản lý sản phẩm</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-product"></i>
                    </div>
                    <ul class="submenu-product">
                        <li><a href="/admin/dashboard/product">Sản phẩm</a></li>
                        <li><a href="/admin/dashboard/category">Loại sản phẩm</a></li>
                        <li><a href="/admin/dashboard/product-images">Hình ảnh sản phẩm</a></li>
                    </ul>
                </li>

                <li class="dropdown-orders">
                    <div class="dropdown-orders-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-cart-shopping"></i> <span>Quản lý đơn hàng</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-orders"></i>
                    </div>
                    <ul class="submenu-orders">
                        <li><a href="/admin/dashboard/orders">Đơn hàng</a></li>
                        <li><a href="/admin/dashboard/order-details">Chi tiết đơn hàng</a></li>
                    </ul>
                </li>

                <li class="dropdown-feedback">
                    <div class="dropdown-feedback-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-comments"></i> <span>Quản lý phản hồi</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-feedback"></i>
                    </div>
                    <ul class="submenu-feedback">
                        <li><a href="/admin/dashboard/feedbacks">Feedback</a></li>
                        <li><a href="/admin/dashboard/product-reviews">Review</a></li>
                    </ul>
                </li>

                <li class="dropdown-product active"> 
                    <div class="dropdown-product-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-newspaper"></i> <span>Quản lý bài viết</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-product"></i>
                    </div>
                    <ul class="submenu-product">
                        <li>
                            <a href="/admin/dashboard/posts" class="active">Bài viết / Tin tức</a>
                        </li>
                    </ul>
                </li>

                <li class="dropdown-menu">
                    <div class="dropdown-toggle">
                        <div class="menu-left">
                            <i class="fa-solid fa-users"></i> <span>Quản lý người dùng</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-icon"></i>
                    </div>
                    <ul class="submenu">
                        <li><a href="/admin/dashboard/customers">Khách hàng</a></li>
                        <li><a href="/admin/dashboard/admin-users">Admin</a></li>
                    </ul>
                </li>
            </ul>
        </aside>

        <main class="main-content">
            <div class="dashboard-header">
                <h1>Quản lý tin tức & bài viết</h1>
                <p>Quản trị nội dung bài đăng trên website</p>
            </div>

            <div class="table-container">
                <div class="table-header">
                    <h3>Danh sách bài viết</h3>
                    <button id="openPostModal" class="btn-add">+ Thêm bài viết</button>
                </div>

                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Hình ảnh</th>
                                <th>Tiêu đề bài viết</th>
                                <th>Chuyên mục</th>
                                <th>Nội dung tóm tắt</th>
                                <th style="text-align: center;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% posts.forEach(post => { %>
                                <tr>
                                    <td><%= post.id %></td>
                                    <td>
                                        <img src="<%= post.thumbnail || '/images/default-thumbnail.jpg' %>" class="post-thumbnail-img" alt="thumbnail">
                                    </td>
                                    <td><div class="text-truncate"><strong><%= post.title %></strong></div></td>
                                    <td><span class="badge"><%= post.cat_name || 'Không xác định' %></span></td>
                                    <td><div class="text-truncate"><%= post.content.replace(/<[^>]*>/g, '') %></div></td>
                                    <td class="actions-cell">
                                        <a href="#" class="btn-edit edit-post-btn" 
                                           data-id="<%= post.id %>"
                                           data-title="<%= post.title %>" 
                                           data-thumbnail="<%= post.thumbnail %>"
                                           data-categoryid="<%= post.category_id %>"
                                           data-summary="<%= post.summary || '' %>"
                                           data-content="<%= post.content %>">
                                            Sửa
                                        </a>
                                        <a href="/admin/dashboard/posts/delete/<%= post.id %>" class="btn-delete" onclick="return confirm('Bạn có chắc muốn xoá bài viết này?')">
                                            Xoá
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>

                    <div class="pagination">
                        <% if (currentPage > 1) { %>
                            <a href="/admin/dashboard/posts?page=<%= currentPage - 1 %>">← Trước</a>
                        <% } %>
                        <% for (let i = 1; i <= totalPages; i++) { %>
                            <a href="/admin/dashboard/posts?page=<%= i %>" class="<%= i === currentPage ? 'active' : '' %>"><%= i %></a>
                        <% } %>
                        <% if (currentPage < totalPages) { %>
                            <a href="/admin/dashboard/posts?page=<%= currentPage + 1 %>">Sau →</a>
                        <% } %>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="postModal" class="modal" style="display:none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; overflow: hidden; background-color: rgba(0,0,0,0.5);">
        <div class="modal-content" style="background-color: #fff; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); padding: 20px; border-radius: 8px; width: 85%; max-width: 1200px; max-height: 90vh; overflow-y: auto; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
            <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 10px; margin-bottom: 15px;">
                <h2>Thêm bài viết mới & Phân đoạn nội dung</h2>
                <span class="close-post-modal" style="font-size: 28px; font-weight: bold; cursor: pointer;">&times;</span>
            </div>
            
            <form id="addPostForm" action="/admin/dashboard/posts/create" method="POST">
                <input type="hidden" name="content" id="add_post_content_hidden">
                
                <div style="display: flex; gap: 25px;">
                    <div class="form-left-panel" style="flex: 4; border-right: 1px solid #eee; padding-right: 20px;">
                        <h3 style="color: #2b78e4; margin-bottom: 15px; font-size: 16px;"><i class="fa-solid fa-circle-info"></i> Thông tin cơ bản</h3>
                        
                        <div class="form-group" style="margin-bottom: 15px;">
                            <label style="display:block; margin-bottom: 5px; font-weight: bold;">Tiêu đề bài viết</label>
                            <input type="text" name="title" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 15px;">
                            <label style="display:block; margin-bottom: 5px; font-weight: bold;">Đường dẫn ảnh chính (Thumbnail URL)</label>
                            <input type="text" name="thumbnail" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 15px;">
                            <label style="display:block; margin-bottom: 5px; font-weight: bold;">Chuyên mục tin tức</label>
                            <select name="category_id" id="add_post_category" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
                                <% categories.forEach(cat => { %>
                                    <option value="<%= cat.id %>"><%= cat.name %></option>
                                        <% }) %>
                            </select>
                        </div>

                        <div style="margin-top: 30px;">
                            <button type="submit" class="btn-save" style="width: 100%; padding: 12px; background: #2b78e4; color: white; border: none; border-radius: 5px; font-size: 15px; font-weight: bold; cursor: pointer;">
                                <i class="fa-solid fa-paper-plane"></i> Đăng bài viết mới
                            </button>
                        </div>
                    </div>
                    
                    <div class="form-right-panel" style="flex: 6; display: flex; flex-direction: column;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                            <h3 style="color: #2b78e4; margin-top: 0; font-size: 16px;"><i class="fa-solid fa-layer-group"></i> Nội dung phân đoạn chi tiết</h3>
                            <button type="button" id="add-block-btn-add-modal" style="background: #2b78e4; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 13px;">
                                <i class="fa-solid fa-plus"></i> Thêm phân đoạn mới
                            </button>
                        </div>
                        
                        <div id="add-dynamic-blocks-container" style="max-height: 420px; overflow-y: auto; padding-right: 5px; border: 1px solid #eee; padding: 10px; border-radius: 6px; background: #fff;">
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div id="editPostModal" class="modal" style="display:none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; overflow: hidden; background-color: rgba(0,0,0,0.5);">
        <div class="modal-content" style="background-color: #fff; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); padding: 20px; border-radius: 8px; width: 85%; max-width: 1200px; max-height: 90vh; overflow-y: auto; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
            <div class="modal-header" style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #eee; padding-bottom: 10px; margin-bottom: 15px;">
                <h2>Xem chi tiết & Quản trị nội dung bài viết</h2>
                <span class="close-edit-post" style="font-size: 28px; font-weight: bold; cursor: pointer;">&times;</span>
            </div>
            
            <form id="editPostForm" method="POST">
                <input type="hidden" name="id" id="edit_post_id">
                <input type="hidden" name="content" id="edit_post_content_hidden">
                
                <div style="display: flex; gap: 25px;">
                    <div class="form-left-panel" style="flex: 4; border-right: 1px solid #eee; padding-right: 20px;">
                        <h3 style="color: #2b78e4; margin-bottom: 15px; font-size: 16px;"><i class="fa-solid fa-circle-info"></i> Form 1: Thông tin cơ bản</h3>
                        
                        <div class="form-group" style="margin-bottom: 15px;">
                            <label style="display:block; margin-bottom: 5px; font-weight: bold;">Tiêu đề bài viết</label>
                            <input type="text" name="title" id="edit_post_title" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 15px;">
                            <label style="display:block; margin-bottom: 5px; font-weight: bold;">Đường dẫn ảnh chính (Thumbnail URL)</label>
                            <input type="text" name="thumbnail" id="edit_post_thumbnail" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 15px;">
                            <label style="display:block; margin-bottom: 5px; font-weight: bold;">Chuyên mục tin tức</label>
                            <select name="category_id" id="edit_post_category" required style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;">
                                <% categories.forEach(cat => { %>
                                    <option value="<%= cat.id %>"><%= cat.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        
                        <div class="form-group" style="margin-bottom: 15px;">
                            <label style="display:block; margin-bottom: 5px; font-weight: bold;">Nội dung tóm tắt (Summary)</label>
                            <textarea name="summary" id="edit_post_summary" rows="4" style="width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px;" placeholder="Tóm tắt ngắn hiện ở trang danh sách..."></textarea>
                        </div>
                        
                        <div style="margin-top: 30px;">
                            <button type="submit" class="btn-save" style="width: 100%; padding: 12px; background: #28a745; color: white; border: none; border-radius: 5px; font-size: 15px; font-weight: bold; cursor: pointer;">
                                <i class="fa-solid fa-floppy-disk"></i> Lưu toàn bộ bài viết
                            </button>
                        </div>
                    </div>
                    
                    <div class="form-right-panel" style="flex: 6; display: flex; flex-direction: column;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
                            <h3 style="color: #2b78e4; margin-top: 0; font-size: 16px;"><i class="fa-solid fa-layer-group"></i> Form 2: Nội dung phân đoạn chi tiết</h3>
                            <button type="button" id="add-block-btn" style="background: #2b78e4; color: white; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 13px;">
                                <i class="fa-solid fa-plus"></i> Thêm phân đoạn mới
                            </button>
                        </div>
                        
                        <div id="dynamic-blocks-container" style="max-height: 420px; overflow-y: auto; padding-right: 5px; border: 1px solid #eee; padding: 10px; border-radius: 6px; background: #fff;">
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
    <script src="/js/post.js"></script>
</body>

</html>