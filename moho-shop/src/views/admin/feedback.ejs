<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý phản hồi khách hàng</title>
    <link rel="stylesheet" href="/css/admin/admindashboard.css">
    <link rel="stylesheet" href="/css/admin/product.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        /* CSS nhãn trạng thái */
        .status-tag {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
            color: #fff;
            display: inline-block;
        }

        .tag-new {
            background-color: #e67e22;
        }

        /* Cam - Mới */
        .tag-read {
            background-color: #2ecc71;
        }

        /* Xanh lá - Đã xem */
        .tag-replied {
            background-color: #3498db;
        }

        /* Xanh dương - Đã trả lời */
        .tag-closed {
            background-color: #95a5a6;
        }

        /* Xám - Đã đóng */

        .message-box-preview {
            max-width: 500px;
            padding: 15px;
            background: #f9f9f9;
            border-left: 4px solid #3498db;
            font-style: italic;
            white-space: pre-line;
            word-break: break-word;
        }
    </style>
</head>

<body>

    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <a href="/admin/dashboard"><img src="/images/banners/LogoMoho.png" alt="Moho Logo"
                        class="sidebar-logo"></a>
            </div>

            <ul class="sidebar-menu">
                <li><a href="/admin/dashboard"><i class="fa-solid fa-chart-line"></i> Tổng quan</a></li>

                <li class="dropdown-product">
                    <div class="dropdown-product-toggle">
                        <div class="menu-left"><i class="fa-solid fa-box"></i><span>Quản lý sản phẩm</span></div>
                        <i class="fa-solid fa-chevron-down arrow-product"></i>
                    </div>
                    <ul class="submenu-product">
                        <li><a href="/admin/dashboard/product">Sản phẩm</a></li>
                        <li><a href="/admin/dashboard/category">Loại sản phẩm</a></li>
                        <li><a href="/admin/dashboard/product-images">Hình ảnh sản phẩm</a></li>
                    </ul>
                </li>

                <li class="dropdown-orders">
                    <div class="dropdown-orders-toggle">
                        <div class="menu-left"><i class="fa-solid fa-cart-shopping"></i><span>Quản lý đơn hàng</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-orders"></i>
                    </div>
                    <ul class="submenu-orders">
                        <li><a href="/admin/orders">Đơn hàng</a></li>
                        <li><a href="/admin/order-details">Chi tiết đơn hàng</a></li>
                    </ul>
                </li>

                <li class="dropdown-feedback active">
                    <div class="dropdown-feedback-toggle">
                        <div class="menu-left"><i class="fa-solid fa-comments"></i><span>Quản lý phản hồi</span></div>
                        <i class="fa-solid fa-chevron-down arrow-feedback"></i>
                    </div>
                    <ul class="submenu-feedback">
                        <li><a href="/admin/dashboard/feedbacks" class="active">Feedback</a></li>
                        <li><a href="/admin/dashboard/product-reviews">Review</a></li>
                    </ul>
                </li>

                <li class="dropdown-menu">
                    <div class="dropdown-toggle">
                        <div class="menu-left"><i class="fa-solid fa-users"></i><span>Quản lý người dùng</span></div>
                        <i class="fa-solid fa-chevron-down arrow-icon"></i>
                    </div>
                    <ul class="submenu">
                        <li><a href="/admin/dashboard/customers">Khách hàng</a></li>
                        <li><a href="/admin/admin-users">Admin</a></li>
                    </ul>
                </li>
            </ul>
        </aside>

        <main class="main-content">
            <div class="dashboard-header">
                <h1>Quản lý góp ý & phản hồi</h1>
                <p>Danh sách tin nhắn đóng góp ý kiến từ khách hàng gửi về trung tâm</p>
            </div>

            <div class="table-container">
                <div class="table-header">
                    <h3>Hòm thư đóng góp</h3>
                </div>

                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Mã KH</th>
                                <th>Họ tên</th>
                                <th>Email liên hệ</th>
                                <th>Trạng thái</th>
                                <th>Ngày gửi</th>
                                <th style="text-align: center;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% feedbacks.forEach(fb=> { %>
                                <tr>
                                    <td>
                                        <%= fb.feedback_id %>
                                    </td>
                                    <td>
                                        <%= fb.customer_id ? fb.customer_id : 'Khách vãng lai' %>
                                    </td>
                                    <td><strong>
                                            <%= fb.fullname || 'Chưa cung cấp' %>
                                        </strong></td>
                                    <td><small>
                                            <%= fb.email || 'Chưa cung cấp' %>
                                        </small></td>
                                    <td>
                                        <span id="status-badge-<%= fb.feedback_id %>"
                                            class="status-tag tag-<%= fb.status %>">
                                            <% if(fb.status==='new' ) { %> Mới <% } %>
                                                    <% if(fb.status==='read' ) { %> Đã xem <% } %>
                                                            <% if(fb.status==='replied' ) { %> Đã trả lời <% } %>
                                                                    <% if(fb.status==='closed' ) { %> Đã đóng <% } %>
                                        </span>
                                    </td>
                                    <td><small>
                                            <%= new Date(fb.created_at).toLocaleString("vi-VN") %>
                                        </small></td>
                                    <td class="actions-cell">
                                        <a href="#" class="btn-edit btn-view-feedback" data-id="<%= fb.feedback_id %>"
                                            data-status="<%= fb.status %>" data-message="<%= fb.message %>">
                                            <i class="fa-regular fa-eye"></i> Xem nội dung
                                        </a>
                                        <a href="/admin/dashboard/feedbacks/delete/<%= fb.feedback_id %>"
                                            class="btn-delete"
                                            onclick="return confirm('Bạn có muốn xóa thư góp ý này không?')">
                                            Xoá
                                        </a>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>

                    <div class="pagination">
                        <% if (currentPage> 1) { %><a href="/admin/dashboard/feedbacks?page=<%= currentPage - 1 %>">←
                                Trước</a>
                            <% } %>
                                <% for (let i=1; i <=totalPages; i++) { %>
                                    <a href="/admin/dashboard/feedbacks?page=<%= i %>"
                                        class="<%= i === currentPage ? 'active' : '' %>">
                                        <%= i %>
                                    </a>
                                    <% } %>
                                        <% if (currentPage < totalPages) { %><a
                                                href="/admin/dashboard/feedbacks?page=<%= currentPage + 1 %>">Sau →</a>
                                            <% } %>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="viewFeedbackModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Nội dung thư góp ý</h2>
                <span class="close-view-feedback">&times;</span>
            </div>
            <div class="form-group" style="margin-top: 15px;">
                <label>Lời nhắn từ khách hàng:</label>
                <div id="modalFeedbackMessage" class="message-box-preview">
                </div>
            </div>
            <div style="text-align: right; margin-top: 20px;">
                <button type="button" class="btn-save close-view-feedback" style="background-color: #7f8c8d;">Đóng
                    lại</button>
            </div>
        </div>
    </div>

    <script src="/js/feedback.js"></script>
</body>

</html>