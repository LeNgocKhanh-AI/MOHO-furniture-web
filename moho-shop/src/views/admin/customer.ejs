<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý khách hàng</title>
    <link rel="stylesheet" href="/css/admin/admindashboard.css">
    <link rel="stylesheet" href="/css/admin/product.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body>

    <div class="dashboard-container">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <a href="/admin/dashboard"><img src="/images/banners/LogoMoho.png" alt="Moho Logo"
                        class="sidebar-logo"></a>
            </div>

            <ul class="sidebar-menu">
                <li><a href="/admin/dashboard"><i class="fa-solid fa-chart-line"></i> Tổng quan</a></li>

                <li class="dropdown-product">
                    <div class="dropdown-product-toggle">
                        <div class="menu-left"><i class="fa-solid fa-box"></i><span>Quản lý sản phẩm</span></div>
                        <i class="fa-solid fa-chevron-down arrow-product"></i>
                    </div>
                    <ul class="submenu-product">
                        <li><a href="/admin/dashboard/product">Sản phẩm</a></li>
                        <li><a href="/admin/dashboard/category">Loại sản phẩm</a></li>
                        <li><a href="/admin/dashboard/product-images">Hình ảnh sản phẩm</a></li>
                            <li><a href="/admin/dashboard/product-sizes">Kích thước sản phẩm</a></li>
                    </ul>
                </li>

                <li class="dropdown-orders">
                    <div class="dropdown-orders-toggle">
                        <div class="menu-left"><i class="fa-solid fa-cart-shopping"></i><span>Quản lý đơn hàng</span>
                        </div>
                        <i class="fa-solid fa-chevron-down arrow-orders"></i>
                    </div>
                    <ul class="submenu-orders">
                        <li><a href="/admin/dashboard/orders">Đơn hàng</a></li>
                        <li><a href="/admin/dashboard/order-details">Chi tiết đơn hàng</a></li>
                    </ul>
                </li>

                <li class="dropdown-feedback">
                    <div class="dropdown-feedback-toggle">
                        <div class="menu-left"><i class="fa-solid fa-comments"></i><span>Quản lý phản hồi</span></div>
                        <i class="fa-solid fa-chevron-down arrow-feedback"></i>
                    </div>
                    <ul class="submenu-feedback">
                        <li><a href="/admin/dashboard/feedbacks">Feedback</a></li>
                        <li><a href="/admin/dashboard/product-reviews">Review</a></li>
                    </ul>
                </li>

                          <li class="dropdown-product">
            <div class="dropdown-product-toggle">
              <div class="menu-left">
                <i class="fa-solid fa-newspaper"></i>
                <span>Quản lý bài viết</span>
              </div>
              <i class="fa-solid fa-chevron-down arrow-product"></i>
            </div>
            <ul class="submenu-product">
              <li>
                <a href="/admin/dashboard/posts"> Bài viết / Tin tức </a>
              </li>
            </ul>
          </li>

                <li class="dropdown-menu active">
                    <div class="dropdown-toggle">
                        <div class="menu-left"><i class="fa-solid fa-users"></i><span>Quản lý người dùng</span></div>
                        <i class="fa-solid fa-chevron-down arrow-icon"></i>
                    </div>
                    <ul class="submenu">
                        <li><a href="/admin/dashboard/customers" class="active">Khách hàng</a></li>
                        <li><a href="/admin/dashboard/admin-users">Admin</a></li>
                    </ul>
                </li>
            </ul>
        </aside>

        <main class="main-content">
            <div class="dashboard-header">
                <h1>Quản lý tài khoản khách hàng</h1>
                <p>Xem danh sách thông tin hồ sơ và quản lý thành viên trên hệ thống</p>
            </div>

            <div class="table-container">
                <div class="table-header">
                    <h3>Danh sách thành viên</h3>
                </div>

                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Username</th>
                                <th>Họ và Tên</th>
                                <th>Giới tính</th>
                                <th>Email</th>
                                <th>Số điện thoại</th>
                                <th>Địa chỉ</th>
                                <th style="text-align: center;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% customers.forEach(cust=> { %>
                                <tr>
                                    <td>
                                        <%= cust.customer_id %>
                                    </td>
                                    <td><span style="color: #2980b9; font-weight: bold;">
                                            <%= cust.customer_username %>
                                        </span></td>
                                    <td><strong>
                                            <%= cust.customer_lastname %>
                                                <%= cust.customer_firstname %>
                                        </strong></td>
                                    <td>
                                        <span class="badge-category">
                                            <%= cust.customer_gender==='Male' ? 'Nam' : cust.customer_gender==='Female'
                                                ? 'Nữ' : 'Khác' %>
                                        </span>
                                    </td>
                                    <td><small>
                                            <%= cust.customer_email || '---' %>
                                        </small></td>
                                    <td>
                                        <%= cust.customer_phone || '---' %>
                                    </td>
                                    <td><small>
                                            <%= cust.customer_address || '---' %>
                                        </small></td>
                                    <td style="text-align: center;">
                                        <a href="/admin/dashboard/customers/delete/<%= cust.customer_id %>"
                                            class="btn-delete"
                                            onclick="return confirm('Bạn có chắc chắn muốn xóa tài khoản khách hàng này vĩnh viễn không?')">
                                            Xóa tài khoản
                                        </a>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>

                    <div class="pagination">
                        <% if (currentPage> 1) { %><a href="/admin/dashboard/customers?page=<%= currentPage - 1 %>">←
                                Trước</a>
                            <% } %>
                                <% for (let i=1; i <=totalPages; i++) { %>
                                    <a href="/admin/dashboard/customers?page=<%= i %>"
                                        class="<%= i === currentPage ? 'active' : '' %>">
                                        <%= i %>
                                    </a>
                                    <% } %>
                                        <% if (currentPage < totalPages) { %><a
                                                href="/admin/dashboard/customers?page=<%= currentPage + 1 %>">Sau →</a>
                                            <% } %>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script src="/js/customer.js"></script>
</body>

</html>